{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "stripInternal": true,
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "skipLibCheck": true,
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "target": "ES2020"
  },
  "include": [
    "src"
  ]
}